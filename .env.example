# Copia este archivo a .env.local y rellena los valores.
# No subas .env.local a Git.
# Reinicia el servidor (`npm run dev`) después de cambiar variables.

# ─── Firebase client (Analytics) ───────────────────────────────────────────
# Recomendadas para habilitar Firebase Analytics en el navegador.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=devlokos.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=devlokos
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=devlokos.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=458512617441
NEXT_PUBLIC_FIREBASE_APP_ID=1:458512617441:web:9423dc5de210ad4f9c8ca0
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-X7DLGDN6HV

# ─── Sitio ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://devlokos.com

# ─── Firebase Admin (Firestore + Remote Config) ──────────────────────────────
# Obligatorio para Academia, Eventos y Empresarial (datos Firestore).
# FIREBASE_ADMIN_SDK_KEY='{"type":"service_account",...}'
FIREBASE_PROJECT_ID=devlokos

# Ambiente Firestore: prod | dev
# Ruta de datos: {FIREBASE_ENV}/{FIREBASE_ENV}/courses y .../events
# Por defecto prod para que local y producción lean los mismos datos.
FIREBASE_ENV=prod

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Obligatorio para Podcast y Tutoriales (o usar Remote Config: youtube_api_key).
# Activa "YouTube Data API v3" en Google Cloud Console.
YOUTUBE_API_KEY=

# Playlist principal del podcast (se excluye de los chips de tutoriales).
YOUTUBE_PLAYLIST_ID=PLPXi7Vgl6Ak-Bm8Y2Xxhp1dwrzWT3AbjZ

# Para Tutoriales: al menos uno de estos (o Remote Config equivalente).
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx
# YOUTUBE_TUTORIALS_PLAYLIST_ID=PLxxxxxxxxxxxxxxxxxx

# ─── Web3Forms (formulario Empresarial) ─────────────────────────────────────
# Recomendado: envío desde el navegador (evita 403 de Cloudflare).
# Clave en https://web3forms.com — puede ser pública según Web3Forms.
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Alternativa: envío desde servidor (requiere plan de pago + whitelist IP).
# WEB3FORMS_ACCESS_KEY=
